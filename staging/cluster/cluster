#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "Usage: $0 <module_id>" >&2
  exit 1
fi

module_id="$(printf "%s" "$1" | tr '[:upper:]' '[:lower:]')"
faa_dir="data/${module_id}_results/faa"
cluster_dir="data/${module_id}_results/clusters"
cluster_tsv="data/${module_id}_results/clusters.tsv"

mkdir -p "$cluster_dir"

rm -f "$cluster_tsv"
rm -f $cluster_dir/*.faa

if [[ ! -d "$faa_dir" ]]; then
  echo "Directory not found: $faa_dir" >&2
  exit 1
fi

found=0
for faa_path in "$faa_dir"/*.faa; do
  [ -e "$faa_path" ] || continue
  found=1
  echo "clustering $faa_path"
  PYTHONPATH=. python3 scripts/cluster/create.py $module_id $faa_path
done

if [[ $found -eq 0 ]]; then
  echo "No .faa files found in $faa_dir" >&2
  exit 1
fi
