{
  "taskGroups": [
    {
      "taskCount": 400,
      "parallelism": 45,
      "taskCountPerNode": 1,
      "taskSpec": {
        "computeResource": {
          "cpuMilli": 4000,
          "memoryMib": 12000
        },
        "maxRetryCount": 5,
        "runnables": [
          {
            "displayName": "Prepare Local Storage and Data",
            "script": {
              "text": "gsutil cp gs://needle-files/experiments/doi:10.1038_s41467-021-25950-4/gc-prepare-hd-pfam.sh ./prepare-hd.sh && bash ./prepare-hd.sh"
            }
          },
          {
            "displayName": "Download Task Specific Assets",
            "script": {
              "text": "gsutil cp gs://needle-files/experiments/doi:10.1038_s41467-021-25950-4/gc-prepare-task-pfam.sh ./prepare_task_${BATCH_TASK_INDEX}.sh && bash ./prepare_task_${BATCH_TASK_INDEX}.sh"
            }
          },
          {
            "displayName": "Run Needle Core HMMScan",
            "container": {
              "imageUri": "us-east1-docker.pkg.dev/needle-489321/needle-docker/needle-core:latest",
              "commands": [
                "/bin/bash",
                "-c",
                "python3 scripts/classify/classify.py --cpu 4 --genome-accession _ --fasta-file /data/input_${BATCH_TASK_INDEX}.faa /data/Pfam-A.hmm _ /data/sequence_pfam_${BATCH_TASK_INDEX}.tsv"
              ],
              "volumes": [
                "/data:/data" 
              ]
            }
          },
          {
            "displayName": "Upload Results",
            "script": {
              "text": "ls -l /data/ && gsutil cp /data/sequence_pfam_${BATCH_TASK_INDEX}.tsv gs://needle-files/experiments/doi:10.1038_s41467-021-25950-4/"
            }
          }
        ]
      }
    }
  ],
  "allocationPolicy": {
    "network": {
      "networkInterfaces": [
        {
          "network": "projects/needle-489321/global/networks/default",
          "subnetwork": "projects/needle-489321/regions/us-east1/subnetworks/default",
          "noExternalIpAddress": true
        }
      ]
    },
    "instances": [
      {
        "installGpuDrivers": false,
        "policy": {
          "machineType": "n2-standard-4",
          "provisioningModel": "SPOT",
          "bootDisk": {
            "sizeGb": 50
          }
        }
      }
    ],
    "location": {
      "allowedLocations": [
        "regions/us-east1"
      ]
    }
  },
  "logsPolicy": {
    "destination": "CLOUD_LOGGING"
  }
}
